{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Work Pulse",
  "version": "0.1.5",
  "identifier": "com.workpulse.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Work Pulse",
        "width": 1180,
        "height": 780,
        "minWidth": 920,
        "minHeight": 620
      },
      {
        "label": "prompt",
        "title": "",
        "url": "prompt.html",
        "width": 360,
        "height": 300,
        "minWidth": 360,
        "maxWidth": 360,
        "minHeight": 300,
        "maxHeight": 300,
        "visible": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "skipTaskbar": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
